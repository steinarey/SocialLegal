# Copy to .env and fill in values, then `docker compose up -d`.
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Active model at startup. Format: provider/model (e.g. anthropic/claude-sonnet-4-6,
# google/gemini-flash-3-preview, openai/gpt-5.4-mini). Override at runtime via /admin.
DEFAULT_MODEL=
INGEST_SECRET=change-me-for-ingest-endpoint
SESSION_SECRET=change-me-random-32-bytes
POSTGRES_PASSWORD=change-me-postgres
